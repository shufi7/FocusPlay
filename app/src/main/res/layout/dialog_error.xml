<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_success">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="14dp"
        android:contentDescription="Karakter gagal"
        android:src="@drawable/karakter_error" />

    <TextView
        android:id="@+id/tvDialogErrorTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/quicksand"
        android:text="Oops!"
        android:textColor="#1F2937"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDialogErrorMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:fontFamily="@font/quicksand"
        android:text="Terjadi kesalahan. Coba lagi ya."
        android:textColor="#6B7280"
        android:textSize="15sp" />

    <ImageButton
        android:id="@+id/btnDialogErrorAction"
        android:layout_width="223dp"
        android:layout_height="56dp"
        android:layout_marginTop="22dp"
        android:adjustViewBounds="true"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:contentDescription="Coba Lagi"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:src="@drawable/btn_cobalagi" />
</LinearLayout>