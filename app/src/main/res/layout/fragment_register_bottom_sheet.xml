<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/registerSheetScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/registerSheetCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="16dp"
        android:paddingBottom="34dp"
        android:background="@drawable/bg_bottom_auth_card">
        <View
            android:layout_width="54dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="22dp"
            android:background="@drawable/bg_drag_handle" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daftar"
            android:textAlignment="center"
            android:textColor="#2D2D2D"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Buat akun baru untuk mulai menggunakan FocusPlay."
            android:textAlignment="center"
            android:textColor="#6B6B6B"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etNamaRegister"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_input_auth"
            android:hint="Nama lengkap"
            android:inputType="textPersonName"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#2D2D2D"
            android:textColorHint="#9A9A9A"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etEmailRegister"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input_auth"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#2D2D2D"
            android:textColorHint="#9A9A9A"
            android:textSize="14sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input_auth">

            <EditText
                android:id="@+id/etPasswordRegister"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Password"
                android:inputType="textPassword"
                android:paddingStart="18dp"
                android:paddingEnd="54dp"
                android:textColor="#2D2D2D"
                android:textColorHint="#9A9A9A"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btnTogglePasswordRegister"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="6dp"
                android:background="@android:color/transparent"
                android:contentDescription="Tampilkan password"
                android:padding="10dp"
                android:src="@drawable/ic_eye" />

        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input_auth">

            <EditText
                android:id="@+id/etKonfirmasiPasswordRegister"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Konfirmasi password"
                android:inputType="textPassword"
                android:paddingStart="18dp"
                android:paddingEnd="54dp"
                android:textColor="#2D2D2D"
                android:textColorHint="#9A9A9A"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btnToggleKonfirmasiPasswordRegister"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="6dp"
                android:background="@android:color/transparent"
                android:contentDescription="Tampilkan konfirmasi password"
                android:padding="10dp"
                android:src="@drawable/ic_eye" />

        </FrameLayout>

        <Button
            android:id="@+id/btnProsesRegister"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:text="Masuk"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMasukSini"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Sudah punya akun? Masuk di sini"
            android:textAlignment="center"
            android:textColor="#7C83FD"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>