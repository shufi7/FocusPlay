<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true"
    android:overScrollMode="never">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="520dp">



        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/bg_card" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="16dp"
            android:paddingEnd="28dp"
            android:paddingBottom="34dp">

            <View
                android:layout_width="54dp"
                android:layout_height="5dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_drag_handle" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/quicksand_bold"
                android:text="LOGIN"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold"
                android:shadowColor="#E66A00"
                android:shadowDx="2"
                android:shadowDy="3"
                android:shadowRadius="1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Masuk ke akun FocusPlay kamu."
                android:textAlignment="center"
                android:textColor="#FFF8F0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:shadowColor="#C45A00"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />

            <EditText
                android:id="@+id/etEmailLogin"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_input_auth"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#5A350E"
                android:textColorHint="#B08A5B"
                android:textSize="14sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_auth">

                <EditText
                    android:id="@+id/etPasswordLogin"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:paddingStart="18dp"
                    android:paddingEnd="54dp"
                    android:textColor="#5A350E"
                    android:textColorHint="#B08A5B"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnTogglePasswordLogin"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="6dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Tampilkan password"
                    android:padding="10dp"
                    android:src="@drawable/ic_eye" />
            </FrameLayout>

            <ImageView
                android:id="@+id/btnProsesLogin"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="22dp"
                android:layout_marginEnd="24dp"
                android:adjustViewBounds="true"
                android:clickable="true"
                android:contentDescription="Masuk"
                android:focusable="true"
                android:scaleType="fitCenter"
                android:src="@drawable/btn_login" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="atau"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:shadowColor="#C45A00"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />

            <ImageView
                android:id="@+id/btnLoginGoogle"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:contentDescription="Masuk dengan Google"
                android:focusable="true"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/google" />

            <TextView
                android:id="@+id/tvDaftarSini"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Belum punya akun? Daftar di sini"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:shadowColor="#C45A00"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />

        </LinearLayout>
    </FrameLayout>
</ScrollView>