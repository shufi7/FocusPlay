<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/backgrounds">

    <LinearLayout
        android:id="@+id/headerPilihAnak"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="22dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBackPilihAnak"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_button_back_orange"
            android:contentDescription="Kembali"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_arrow_back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/quicksand_bold"
                android:text="Pilih Profil Anak"
                android:textColor="#2F2F2F"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        app:cardBackgroundColor="#FFFBF7"
        app:cardCornerRadius="32dp"
        app:cardElevation="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerPilihAnak">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="18dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFF1E6"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <View
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="-45dp"
                        android:background="@drawable/bg_circle_orange_soft" />

                    <View
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_gravity="end|bottom"
                        android:layout_marginEnd="48dp"
                        android:layout_marginBottom="-28dp"
                        android:background="@drawable/bg_circle_peach_soft" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="118dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/quicksand_bold"
                                android:text="Siap bermain hari ini?"
                                android:textColor="#2F2F2F"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/quicksand"
                                android:lineSpacingExtra="2dp"
                                android:maxLines="2"
                                android:text="Pilih profil anak untuk masuk ke daftar permainan FocusPlay."
                                android:textColor="#7A6B5D"
                                android:textSize="12.5sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:background="@drawable/bg_badge_orange_soft"
                                android:fontFamily="@font/quicksand_bold"
                                android:gravity="center"
                                android:paddingTop="6dp"
                                android:paddingBottom="6dp"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:text="Latihan fokus anak"
                                android:textColor="#C56A10"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="82dp"
                            android:layout_height="82dp"
                            android:adjustViewBounds="true"
                            android:contentDescription="Karakter"
                            android:scaleType="fitCenter"
                            android:src="@drawable/karakter_anak" />

                    </LinearLayout>

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/quicksand_bold"
                        android:text="Daftar Profil"
                        android:textColor="#2F2F2F"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/quicksand"
                        android:text="Pilih salah satu profil untuk melanjutkan"
                        android:textColor="#7A6B5D"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#FFF8F1"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:nestedScrollingEnabled="true"
                    android:overScrollMode="ifContentScrolls"
                    android:padding="12dp"
                    android:scrollbarStyle="outsideOverlay"
                    android:smoothScrollbar="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvEmptyState"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_empty_profile_orange"
                            android:fontFamily="@font/quicksand"
                            android:gravity="center"
                            android:lineSpacingExtra="3dp"
                            android:paddingStart="16dp"
                            android:paddingTop="18dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="18dp"
                            android:text="Belum ada profil anak.\nTambahkan profil melalui Dashboard Orang Tua terlebih dahulu."
                            android:textColor="#7A6B5D"
                            android:textSize="13sp" />

                        <LinearLayout
                            android:id="@+id/containerProfilAnak"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />

                    </LinearLayout>

                </ScrollView>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>