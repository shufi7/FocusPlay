<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/backgrounds">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerPilihAnak"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="22dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBackPilihAnak"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/btn_back"
            android:contentDescription="Kembali"
            android:padding="11dp"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/quicksand_bold"
                android:maxLines="1"
                android:text="Pilih Profil Anak"
                android:textColor="#1F2937"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>



    </LinearLayout>

    <!-- Card utama -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPilihAnak"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        app:cardBackgroundColor="#FDFDFD"
        app:cardCornerRadius="28dp"
        app:cardElevation="3dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerPilihAnak">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Hero Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="92dp"
                app:cardBackgroundColor="#F4EEFF"
                app:cardCornerRadius="22dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/quicksand"
                            android:maxLines="1"
                            android:text="Halo, siap bermain?"
                            android:textColor="#1F2937"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:fontFamily="@font/quicksand"
                            android:maxLines="2"
                            android:text="Pilih profil anak untuk mulai latihan fokus."
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="110dp"
                            android:layout_height="5dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_splash_ribbon" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="62dp"
                        android:layout_height="62dp"
                        android:adjustViewBounds="true"
                        android:contentDescription="Karakter"
                        android:scaleType="fitCenter"
                        android:src="@drawable/karakter_anak" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Judul -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/quicksand"
                android:text="Daftar Profil Anak"
                android:textColor="#1F2937"
                android:textSize="19sp"
                android:textStyle="bold" />

            <!-- Tombol tambah -->
            <LinearLayout
                android:id="@+id/btnTambahProfilAnak"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="76dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_add_child_card"
                android:clickable="true"
                android:elevation="1dp"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_circle_arrow"
                    android:fontFamily="@font/quicksand"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/quicksand"
                        android:text="Tambah Profil Anak"
                        android:textColor="#1F2937"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/quicksand"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text="Daftarkan anak baru"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Daftar anak -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#F8FAFC"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <ScrollView
                    android:id="@+id/scrollDaftarAnak"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:nestedScrollingEnabled="true"
                    android:overScrollMode="ifContentScrolls"
                    android:padding="10dp"
                    android:scrollbarStyle="outsideOverlay"
                    android:smoothScrollbar="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvEmptyState"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_info_soft"
                            android:fontFamily="@font/quicksand"
                            android:gravity="center"
                            android:padding="14dp"
                            android:text="Belum ada profil anak. Tambahkan profil terlebih dahulu."
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                        <LinearLayout
                            android:id="@+id/containerProfilAnak"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />

                    </LinearLayout>
                </ScrollView>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>