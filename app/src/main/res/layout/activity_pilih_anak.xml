<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_playground">

    <!-- Dekorasi awan kiri -->

    <!-- Dekorasi awan kanan -->
    <View
        android:id="@+id/cloudRight"
        android:layout_width="135dp"
        android:layout_height="40dp"
        android:layout_marginTop="58dp"
        android:layout_marginEnd="-28dp"
        android:alpha="0.88"
        android:background="@drawable/bg_cloud"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Area hijau bawah hanya sebagai background -->
    <View
        android:id="@+id/groundBottomPilihAnak"
        android:layout_width="0dp"
        android:layout_height="155dp"
        android:background="@drawable/bg_ground_soft"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:layout_width="235dp"
        android:layout_height="100dp"
        android:layout_marginStart="-48dp"
        android:layout_marginBottom="80dp"
        android:background="@drawable/bg_hill"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:layout_width="250dp"
        android:layout_height="106dp"
        android:layout_marginEnd="-55dp"
        android:layout_marginBottom="76dp"
        android:background="@drawable/bg_hill"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerPilihAnak"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginTop="34dp"
        android:layout_marginEnd="22dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBackPilihAnak"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_back_circle"
            android:contentDescription="Kembali"
            android:padding="11dp"
            android:src="@drawable/ic_arrow_back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/quicksand"
                android:text="Pilih Profil Anak"
                android:textColor="#1F2937"
                android:textSize="25sp"
                android:textStyle="bold" />

        </LinearLayout>

        <ImageView
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:contentDescription="Karakter hati"
            android:src="@drawable/char_heart" />

    </LinearLayout>

    <!-- Card utama dibuat lebih panjang sampai bawah -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPilihAnak"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="22dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="26dp"
        app:cardBackgroundColor="#FDFDFD"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerPilihAnak"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Hero card diperkecil agar daftar anak lebih luas -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="92dp"
                app:cardBackgroundColor="#F4EEFF"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quicksand"
                            android:text="Halo, siap bermain?"
                            android:textColor="#1F2937"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/quicksand"
                            android:text="Pilih profil anak untuk mulai latihan fokus."
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="118dp"
                            android:layout_height="5dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_splash_ribbon" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="66dp"
                        android:layout_height="66dp"
                        android:contentDescription="Karakter"
                        android:src="@drawable/char_moon_purple" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Judul daftar -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/quicksand"
                android:text="Daftar Profil Anak"
                android:textColor="#1F2937"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Tombol tambah tetap terlihat -->
            <LinearLayout
                android:id="@+id/btnTambahProfilAnak"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_add_child_card"
                android:clickable="true"
                android:elevation="2dp"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_circle_arrow"
                    android:fontFamily="@font/quicksand"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/quicksand"
                        android:text="Tambah Profil Anak"
                        android:textColor="#1F2937"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/quicksand"
                        android:text="Daftarkan anak baru"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Area daftar anak dibuat jauh lebih tinggi -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#F8FAFC"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <ScrollView
                    android:id="@+id/scrollDaftarAnak"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:overScrollMode="ifContentScrolls"
                    android:padding="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvEmptyState"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_info_soft"
                            android:fontFamily="@font/quicksand"
                            android:gravity="center"
                            android:padding="14dp"
                            android:text="Belum ada profil anak. Tambahkan profil terlebih dahulu."
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                        <LinearLayout
                            android:id="@+id/containerProfilAnak"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />

                    </LinearLayout>
                </ScrollView>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>