<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_splash_playground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Dekorasi awan -->
        <View
            android:id="@+id/cloudTopLeft"
            android:layout_width="110dp"
            android:layout_height="34dp"
            android:layout_marginTop="78dp"
            android:layout_marginStart="-18dp"
            android:background="@drawable/bg_cloud"
            android:alpha="0.85"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/cloudTopRight"
            android:layout_width="125dp"
            android:layout_height="38dp"
            android:layout_marginTop="64dp"
            android:layout_marginEnd="-18dp"
            android:background="@drawable/bg_cloud"
            android:alpha="0.85"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Bubble -->
        <View
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginTop="56dp"
            android:layout_marginStart="28dp"
            android:background="@drawable/bg_bubble"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginTop="52dp"
            android:layout_marginEnd="36dp"
            android:background="@drawable/bg_bubble"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo -->
        <LinearLayout
            android:id="@+id/headerBox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="58dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:contentDescription="Logo FocusPlay"
                android:src="@drawable/logo_focusplay" />
        </LinearLayout>

        <!-- Card Login -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardLogin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="180dp"
            app:cardBackgroundColor="#FDFDFD"
            app:cardCornerRadius="30dp"
            app:cardElevation="6dp"
            app:layout_constraintTop_toBottomOf="@id/headerBox"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quicksand"
                            android:text="Masuk Akun"
                            android:textColor="#1F2937"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/quicksand"
                            android:text="Ayo lanjutkan permainan serumu"
                            android:textColor="#7B8794"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:contentDescription="Karakter hati"
                        android:src="@drawable/char_heart" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/quicksand"
                    android:text="Email"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_login"
                    android:fontFamily="@font/quicksand"
                    android:hint="Masukkan email"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1F2937"
                    android:textColorHint="#A0AEC0"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="@font/quicksand"
                    android:text="Password"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_login"
                    android:fontFamily="@font/quicksand"
                    android:hint="Masukkan password"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1F2937"
                    android:textColorHint="#A0AEC0"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_green"
                    android:fontFamily="@font/quicksand"
                    android:text="Masuk"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnLoginGoogle"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_white_outline"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/quicksand"
                    android:gravity="center"
                    android:text="Masuk dengan Google"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="14dp"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/quicksand"
                    android:text="Daftar Akun"
                    android:textAllCaps="false"
                    android:textColor="#2F80ED"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Area bawah -->
        <View
            android:id="@+id/groundBottom"
            android:layout_width="0dp"
            android:layout_height="190dp"
            android:background="@drawable/bg_ground_soft"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:layout_width="230dp"
            android:layout_height="110dp"
            android:layout_marginStart="-44dp"
            android:layout_marginBottom="96dp"
            android:background="@drawable/bg_hill"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:layout_width="250dp"
            android:layout_height="118dp"
            android:layout_marginEnd="-56dp"
            android:layout_marginBottom="90dp"
            android:background="@drawable/bg_hill"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Karakter bawah -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginStart="18dp"
            android:layout_marginBottom="64dp"
            android:contentDescription="Karakter cloud biru"
            android:src="@drawable/char_cloud_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginBottom="86dp"
            android:contentDescription="Karakter cucumber"
            android:src="@drawable/char_cucumber"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="60dp"
            android:contentDescription="Karakter moon ungu"
            android:src="@drawable/char_moon_purple"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>