<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_success">

    <ImageView
        android:id="@+id/ivDialogCharacter"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_marginBottom="14dp"
        android:contentDescription="Karakter sukses"
        android:src="@drawable/char_moon_purple" />

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/quicksand"
        android:text="Berhasil!"
        android:textColor="#1F2937"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDialogMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:fontFamily="@font/quicksand"
        android:text="Yeay! Kamu berhasil masuk ke FocusPlay."
        android:textColor="#6B7280"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnDialogAction"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_button_green"
        android:backgroundTint="@null"
        android:fontFamily="@font/quicksand"
        android:text="Lanjut"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>