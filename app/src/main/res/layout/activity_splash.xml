<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_playground">

    <!-- Bubble dekorasi -->
    <View
        android:id="@+id/bubbleTopLeft"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="36dp"
        android:layout_marginTop="70dp"
        android:background="@drawable/bg_bubble"
        android:alpha="0.75"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bubbleTopRight"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="42dp"
        android:background="@drawable/bg_bubble"
        android:alpha="0.65"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bubbleMiddle"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginStart="52dp"
        android:layout_marginBottom="250dp"
        android:background="@drawable/bg_bubble"
        android:alpha="0.55"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Awan -->
    <View
        android:id="@+id/cloudLeft"
        android:layout_width="118dp"
        android:layout_height="36dp"
        android:layout_marginStart="-20dp"
        android:layout_marginTop="118dp"
        android:background="@drawable/bg_cloud"
        android:alpha="0.85"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/cloudRight"
        android:layout_width="140dp"
        android:layout_height="42dp"
        android:layout_marginTop="96dp"
        android:layout_marginEnd="-28dp"
        android:background="@drawable/bg_cloud"
        android:alpha="0.80"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Logo atas seperti title game -->
    <LinearLayout
        android:id="@+id/logoHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="88dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:contentDescription="Logo FocusPlay"
            android:src="@drawable/logo_focusplay" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-4dp"
            android:fontFamily="@font/quicksand"
            android:shadowColor="#80FFFFFF"
            android:shadowDx="0"
            android:shadowDy="3"
            android:shadowRadius="4"
            android:text="FocusPlay"
            android:textColor="#FFF06A"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_splash_ribbon"
            android:fontFamily="@font/quicksand"
            android:paddingHorizontal="20dp"
            android:paddingVertical="7dp"
            android:text="Belajar fokus sambil bermain"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Area playground / tanah bawah -->
    <View
        android:id="@+id/ground"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_ground_soft"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bukit hijau -->
    <View
        android:id="@+id/hillLeft"
        android:layout_width="230dp"
        android:layout_height="120dp"
        android:layout_marginStart="-40dp"
        android:layout_marginBottom="112dp"
        android:background="@drawable/bg_hill"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/hillRight"
        android:layout_width="250dp"
        android:layout_height="130dp"
        android:layout_marginEnd="-65dp"
        android:layout_marginBottom="104dp"
        android:background="@drawable/bg_hill"
        android:alpha="0.9"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Karakter utama -->
    <ImageView
        android:id="@+id/ivBlue"
        android:layout_width="118dp"
        android:layout_height="118dp"
        android:layout_marginStart="30dp"
        android:layout_marginBottom="106dp"
        android:contentDescription="Karakter biru"
        android:src="@drawable/char_blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/ivStar"
        android:layout_width="142dp"
        android:layout_height="142dp"
        android:layout_marginBottom="124dp"
        android:contentDescription="Karakter bintang"
        android:src="@drawable/char_star"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.52"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/ivMushroom"
        android:layout_width="112dp"
        android:layout_height="112dp"
        android:layout_marginEnd="26dp"
        android:layout_marginBottom="106dp"
        android:contentDescription="Karakter jamur"
        android:src="@drawable/char_mushroom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Karakter kecil dekorasi -->
    <ImageView
        android:id="@+id/ivRed"
        android:layout_width="78dp"
        android:layout_height="78dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="42dp"
        android:contentDescription="Karakter merah"
        android:rotation="-8"
        android:src="@drawable/char_red"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/ivPurple"
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="36dp"
        android:contentDescription="Karakter ungu"
        android:rotation="8"
        android:src="@drawable/char_purple"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Loading card -->
    <LinearLayout
        android:id="@+id/loadingCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="96dp"
        android:background="@drawable/bg_loading_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ProgressBar
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminateTint="#8DB52A" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/quicksand"
            android:text="Menyiapkan permainan..."
            android:textColor="#4B5563"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/quicksand"
        android:text="Aman &amp; menyenangkan untuk anak"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>