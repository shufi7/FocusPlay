<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_playground"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbarStyle="outsideOverlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="270dp"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="30dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivBackDashboard"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_back_circle"
                    android:contentDescription="Kembali"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_arrow_back" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvWelcomeName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/quicksand"
                        android:maxLines="1"
                        android:text="Halo, Orang Tua!"
                        android:textColor="#1F2937"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:ellipsize="end"
                        android:fontFamily="@font/quicksand"
                        android:maxLines="2"
                        android:text="Pantau perkembangan fokus anak hari ini"
                        android:textColor="#406915"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Hero Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#F4EEFF"
                app:cardCornerRadius="26dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="120dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/quicksand"
                            android:maxLines="1"
                            android:text="Dashboard Orang Tua"
                            android:textColor="#1F2937"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:ellipsize="end"
                            android:fontFamily="@font/quicksand"
                            android:maxLines="2"
                            android:text="Kelola profil anak dan pantau aktivitas bermain."
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="120dp"
                            android:layout_height="5dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_splash_ribbon" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:adjustViewBounds="true"
                        android:contentDescription="Karakter dashboard"
                        android:scaleType="fitCenter"
                        android:src="@drawable/char_heart" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <!-- PROFIL ANAK PANEL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="26dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:fontFamily="@font/quicksand"
                                android:maxLines="1"
                                android:text="Profil Anak"
                                android:textColor="#1F2937"
                                android:textSize="19sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:ellipsize="end"
                                android:fontFamily="@font/quicksand"
                                android:maxLines="2"
                                android:text="Pilih atau tambah profil anak"
                                android:textColor="#6B7280"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:adjustViewBounds="true"
                            android:contentDescription="Karakter profil anak"
                            android:scaleType="fitCenter"
                            android:src="@drawable/char_moon_purple" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvProfilAnakKosong"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_info_soft"
                        android:fontFamily="@font/quicksand"
                        android:gravity="center"
                        android:padding="14dp"
                        android:text="Memuat profil anak..."
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                    <HorizontalScrollView
                        android:id="@+id/horizontalProfilAnak"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginTop="14dp"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/containerProfilAnakDashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- GRAFIK PANEL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="26dp"
                app:cardElevation="2dp">

                <com.example.focusplay.view.WeeklyLineChartView
                    android:id="@+id/chartWeekly"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#FFFFFF"
                    android:padding="12dp" />
            </androidx.cardview.widget.CardView>

            <!-- MENU ORANG TUA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/quicksand"
                android:text="Menu Orang Tua"
                android:textColor="#1F2937"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Riwayat Permainan -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="74dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="22dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/btnRiwayatPermainan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="74dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_info_soft"
                        android:gravity="center"
                        android:text="📊"
                        android:textSize="19sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/quicksand"
                            android:maxLines="1"
                            android:text="Riwayat Permainan"
                            android:textColor="#1F2937"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:ellipsize="end"
                            android:fontFamily="@font/quicksand"
                            android:maxLines="2"
                            android:text="Lihat hasil sesi bermain anak"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_arrow"
                        android:contentDescription="Lanjut"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_arrow_right" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pengaturan Permainan -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="74dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="22dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/btnPengaturanPermainan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="74dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_info_soft"
                        android:gravity="center"
                        android:text="⚙"
                        android:textSize="19sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/quicksand"
                            android:maxLines="1"
                            android:text="Pengaturan Permainan"
                            android:textColor="#1F2937"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:ellipsize="end"
                            android:fontFamily="@font/quicksand"
                            android:maxLines="2"
                            android:text="Atur sesi dan mode bermain"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_arrow"
                        android:contentDescription="Lanjut"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_arrow_right" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Logout -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_red"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/quicksand"
                    android:text="Logout"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>