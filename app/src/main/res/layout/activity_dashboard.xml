<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_playground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="292dp"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="34dp"
            android:paddingEnd="24dp">

            <!-- Header atas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivBackDashboard"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_back_circle"
                    android:contentDescription="Kembali"
                    android:padding="11dp"
                    android:src="@drawable/ic_arrow_back" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvWelcomeName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/quicksand"
                        android:text="Halo, Orang Tua!"
                        android:textColor="#1F2937"
                        android:textSize="25sp"
                        android:textStyle="bold"
                        android:shadowColor="#CCFFFFFF"
                        android:shadowDx="0"
                        android:shadowDy="2"
                        android:shadowRadius="3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:fontFamily="@font/quicksand"
                        android:text="Pantau perkembangan fokus anak hari ini"
                        android:textColor="#406915"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Hero Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="126dp"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="#F4EEFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingEnd="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quicksand"
                            android:text="Dashboard Orang Tua"
                            android:textColor="#1F2937"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/quicksand"
                            android:text="Pilih profil anak untuk melihat grafik, riwayat, dan evaluasi AI."
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                        <View
                            android:layout_width="128dp"
                            android:layout_height="5dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_splash_ribbon" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:contentDescription="Karakter dashboard"
                        android:src="@drawable/char_heart" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="34dp">

            <!-- PROFIL ANAK PANEL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/quicksand"
                                android:text="Profil Anak"
                                android:textColor="#1F2937"
                                android:textSize="21sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/quicksand"
                                android:text="Pilih anak yang ingin dipantau"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:contentDescription="Karakter profil anak"
                            android:src="@drawable/char_moon_purple" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvProfilAnakKosong"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_info_soft"
                        android:fontFamily="@font/quicksand"
                        android:gravity="center"
                        android:padding="14dp"
                        android:text="Memuat profil anak..."
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                    <HorizontalScrollView
                        android:id="@+id/horizontalProfilAnak"
                        android:layout_width="match_parent"
                        android:layout_height="148dp"
                        android:layout_marginTop="14dp"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/containerProfilAnakDashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- GRAFIK PANEL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="5dp">

                <com.example.focusplay.view.WeeklyLineChartView
                    android:id="@+id/chartWeekly"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#FFFFFF"
                    android:padding="14dp" />
            </androidx.cardview.widget.CardView>

            <!-- RECAP EVALUASI AI -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardRecapAi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Header Recap AI -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvJudulRecapAi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/quicksand"
                                android:text="Recap Evaluasi AI"
                                android:textColor="#1F2937"
                                android:textSize="21sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvSubjudulRecapAi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/quicksand"
                                android:text="Ringkasan analisis dari sesi bermain anak"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvHintSwipeAi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/quicksand"
                                android:text="Geser ke samping untuk melihat semua evaluasi"
                                android:textColor="#8DB52A"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:background="@drawable/bg_info_soft"
                                android:gravity="center"
                                android:text="AI"
                                android:textColor="#406915"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="6dp"
                                android:background="@drawable/bg_circle_arrow"
                                android:contentDescription="Geser ke samping"
                                android:padding="8dp"
                                android:src="@drawable/ic_arrow_right" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAiRecapKosong"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_info_soft"
                        android:fontFamily="@font/quicksand"
                        android:gravity="center"
                        android:padding="16dp"
                        android:text="Belum ada evaluasi AI. Evaluasi akan muncul setelah anak menyelesaikan permainan."
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                    <HorizontalScrollView
                        android:id="@+id/scrollAiRecap"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/containerAiRecap"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- MENU ORANG TUA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/quicksand"
                android:text="Menu Orang Tua"
                android:textColor="#1F2937"
                android:textSize="21sp"
                android:textStyle="bold" />

            <!-- Riwayat Permainan -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:id="@+id/btnRiwayatPermainan"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp">

                    <TextView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_info_soft"
                        android:gravity="center"
                        android:text="📊"
                        android:textSize="20sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quicksand"
                            android:text="Riwayat Permainan"
                            android:textColor="#1F2937"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/quicksand"
                            android:text="Lihat hasil sesi bermain anak"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_circle_arrow"
                        android:contentDescription="Lanjut"
                        android:padding="8dp"
                        android:src="@drawable/ic_arrow_right" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pengaturan Permainan -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:id="@+id/btnPengaturanPermainan"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp">

                    <TextView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_info_soft"
                        android:gravity="center"
                        android:text="⚙"
                        android:textSize="20sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quicksand"
                            android:text="Pengaturan Permainan"
                            android:textColor="#1F2937"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/quicksand"
                            android:text="Atur sesi dan mode bermain"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_circle_arrow"
                        android:contentDescription="Lanjut"
                        android:padding="8dp"
                        android:src="@drawable/ic_arrow_right" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Logout -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_red"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/quicksand"
                    android:text="Logout"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>