<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fff">

    <ImageView
        android:id="@+id/bgDeskripsiGame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HERO FULL ATAS -->
            <FrameLayout
                android:id="@+id/heroContainer"
                android:layout_width="match_parent"
                android:layout_height="360dp">

                <!-- Gambar game diisi dari file KT -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgGame"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#fff"
                    tools:src="@drawable/bg_antardomba"
                    app:shapeAppearanceOverlay="@style/BottomRoundedHeroImage" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                   />

                <!-- Header: Back Button & Title (Cloud Style) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_marginTop="28dp"
                    android:elevation="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    android:paddingStart="6dp"
                    android:paddingEnd="24dp">

                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_button_back_orange"
                        android:padding="14dp"
                        android:src="@drawable/ic_arrow_back" />

                    <TextView
                        android:id="@+id/tvHeaderTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:fontFamily="@font/quicksand_bold"
                        android:text="Deskripsi Game"
                        android:textColor="#3F2A1D"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </FrameLayout>

            <!-- CARD ISI DESKRIPSI -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDeskripsiGame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="-34dp"
                android:layout_marginEnd="22dp"
                android:layout_marginBottom="30dp"
                app:cardBackgroundColor="#FFFDF2"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingTop="24dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="26dp">

                    <!-- Nama game diisi dari KT -->
                    <TextView
                        android:id="@+id/tvNamaGame"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/quicksand_bold"
                        android:gravity="center"
                        android:textColor="#7A3E18"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="Antar Domba ke Rumah" />

                    <View
                        android:layout_width="80dp"
                        android:layout_height="5dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_line_orange" />

                    <!-- Tujuan Permainan -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:background="@drawable/bg_circle_soft_green">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="🎯"
                                android:textSize="28sp" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_label_soft_green"
                                android:fontFamily="@font/quicksand_bold"
                                android:paddingStart="18dp"
                                android:paddingTop="5dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="5dp"
                                android:text="Tujuan Permainan"
                                android:textColor="#2E7D32"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <!-- Isi tujuan dari KT -->
                            <TextView
                                android:id="@+id/tvTujuanGame"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="9dp"
                                android:fontFamily="@font/quicksand"
                                android:lineSpacingExtra="4dp"
                                android:textColor="#3F2A1D"
                                android:textSize="15sp"
                                tools:text="Melatih fokus, perhatian, dan ketepatan memilih tujuan." />

                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="22dp"
                        android:background="#FFE0B2" />

                    <!-- Cara Bermain -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:background="@drawable/bg_circle_soft_blue">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="📖"
                                android:textSize="28sp" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_label_soft_blue"
                                android:fontFamily="@font/quicksand_bold"
                                android:paddingStart="18dp"
                                android:paddingTop="5dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="5dp"
                                android:text="Cara Bermain"
                                android:textColor="#1565C0"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <!-- Isi cara bermain dari KT -->
                            <TextView
                                android:id="@+id/tvCaraBermain"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:fontFamily="@font/quicksand"
                                android:lineSpacingExtra="6dp"
                                android:textColor="#3F2A1D"
                                android:textSize="15sp"
                                tools:text="1. Perhatikan rumah tujuan.\n2. Arahkan domba ke rumah yang benar.\n3. Kumpulkan skor sebanyak mungkin." />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Tombol tetap Button supaya aman kalau di KT pakai Button -->
                    <ImageView
                        android:id="@+id/btnMulaiGame"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginStart="32dp"
                        android:layout_marginTop="26dp"
                        android:layout_marginEnd="32dp"
                        android:adjustViewBounds="true"
                        android:clickable="true"
                        android:focusable="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/btn_bermain" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</FrameLayout>