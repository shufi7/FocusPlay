<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/backgrounds" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_circle_white" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFF7D6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvNamaGame"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Antar ke Rumah"
                        android:textColor="#8B3A3A"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/quicksand_bold" />

                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="18dp"
                        android:src="@drawable/domba_putih"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Tujuan Permainan"
                        android:textColor="#B24B4B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/quicksand_bold" />

                    <TextView
                        android:id="@+id/tvTujuanGame"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#4B5563"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Cara Bermain"
                        android:textColor="#B24B4B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/quicksand_bold" />

                    <TextView
                        android:id="@+id/tvCaraBermain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#4B5563"
                        android:textSize="15sp"
                        android:lineSpacingExtra="5dp" />

                    <Button
                        android:id="@+id/btnMulaiGame"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="28dp"
                        android:text="Mulai Bermain"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:backgroundTint="#F59E0B"
                        app:cornerRadius="28dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</FrameLayout>