<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_splash_playground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Dekorasi awan -->
        <View
            android:id="@+id/cloudLeft"
            android:layout_width="120dp"
            android:layout_height="36dp"
            android:layout_marginStart="-22dp"
            android:layout_marginTop="78dp"
            android:alpha="0.85"
            android:background="@drawable/bg_cloud"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/cloudRight"
            android:layout_width="135dp"
            android:layout_height="40dp"
            android:layout_marginTop="58dp"
            android:layout_marginEnd="-28dp"
            android:alpha="0.85"
            android:background="@drawable/bg_cloud"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Bubble dekorasi -->
        <View
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="32dp"
            android:layout_marginTop="54dp"
            android:background="@drawable/bg_bubble"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="38dp"
            android:background="@drawable/bg_bubble"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Header -->
        <LinearLayout
            android:id="@+id/headerPeran"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="50dp"
            android:layout_marginEnd="24dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivLogoPeran"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:contentDescription="Logo FocusPlay"
                android:src="@drawable/logo_focusplay" />

            <TextView
                android:id="@+id/tvNamaUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/quicksand"
                android:gravity="center"
                android:text="Halo!"
                android:textColor="#FFFFFF"
                android:textSize="25sp"
                android:textStyle="bold"
                android:shadowColor="#2F80ED"
                android:shadowDx="0"
                android:shadowDy="3"
                android:shadowRadius="3" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_splash_ribbon"
                android:fontFamily="@font/quicksand"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:paddingVertical="7dp"
                android:text="Kamu ingin masuk sebagai siapa?"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card container -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardContainerPeran"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="22dp"
            app:cardBackgroundColor="#FDFDFD"
            app:cardCornerRadius="30dp"
            app:cardElevation="6dp"
            app:layout_constraintTop_toBottomOf="@id/headerPeran"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- Judul -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quicksand"
                            android:text="Pilih Peran"
                            android:textColor="#1F2937"
                            android:textSize="27sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/quicksand"
                            android:text="Masuk sesuai kebutuhanmu hari ini"
                            android:textColor="#7B8794"
                            android:textSize="14sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Card Orang Tua -->
                <LinearLayout
                    android:id="@+id/cardOrangTua"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_role_parent"
                    android:clickable="true"
                    android:elevation="2dp"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="78dp"
                        android:layout_height="78dp"
                        android:contentDescription="Karakter orang tua"
                        android:src="@drawable/char_cloud_blue" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="15dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quicksand"
                            android:text="Orang Tua"
                            android:textColor="#1F2937"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/quicksand"
                            android:text="Pantau progres dan kelola aktivitas anak"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_circle_arrow"
                        android:contentDescription="Lanjut"
                        android:padding="8dp"
                        android:src="@drawable/ic_arrow_right" />
                </LinearLayout>

                <!-- Card Anak -->
                <LinearLayout
                    android:id="@+id/cardAnak"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_role_child"
                    android:clickable="true"
                    android:elevation="2dp"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="78dp"
                        android:layout_height="78dp"
                        android:contentDescription="Karakter anak"
                        android:src="@drawable/char_mushroom" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="15dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quicksand"
                            android:text="Anak"
                            android:textColor="#1F2937"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/quicksand"
                            android:text="Mulai bermain dan latihan fokus"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_circle_arrow"
                        android:contentDescription="Lanjut"
                        android:padding="8dp"
                        android:src="@drawable/ic_arrow_right" />
                </LinearLayout>

                <!-- Info bawah -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_info_soft"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:contentDescription="Karakter diamond"
                        android:src="@drawable/char_star" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/quicksand"
                        android:text="FocusPlay membantu anak belajar fokus dengan cara yang menyenangkan."
                        android:textColor="#5A6B76"
                        android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Area bawah playground -->
        <View
            android:id="@+id/groundBottomPeran"
            android:layout_width="0dp"
            android:layout_height="190dp"
            android:background="@drawable/bg_ground_soft"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:layout_width="235dp"
            android:layout_height="112dp"
            android:layout_marginStart="-48dp"
            android:layout_marginBottom="94dp"
            android:background="@drawable/bg_hill"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:layout_width="250dp"
            android:layout_height="118dp"
            android:layout_marginEnd="-55dp"
            android:layout_marginBottom="88dp"
            android:background="@drawable/bg_hill"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Karakter bawah -->
        <ImageView
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_marginStart="18dp"
            android:layout_marginBottom="48dp"
            android:contentDescription="Karakter cloud blue"
            android:src="@drawable/char_cloud_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="48dp"
            android:contentDescription="Karakter moon purple"
            android:src="@drawable/char_moon_purple"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>