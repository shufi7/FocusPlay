<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#BFEAFB">

    <!-- Dekorasi atas -->
    <View
        android:layout_width="130dp"
        android:layout_height="36dp"
        android:layout_marginStart="-20dp"
        android:layout_marginTop="42dp"
        android:background="@android:color/white"
        android:alpha="0.65" />

    <View
        android:layout_width="100dp"
        android:layout_height="30dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="-10dp"
        android:background="@android:color/white"
        android:alpha="0.65" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/ivLogoPeran"
                android:layout_width="105dp"
                android:layout_height="105dp"
                android:layout_marginTop="36dp"
                android:src="@drawable/logo_focusplay"
                android:contentDescription="Logo FocusPlay" />

            <TextView
                android:id="@+id/tvNamaUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Halo!"
                android:textColor="#2F3A2E"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="@font/quicksand" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Kamu ingin masuk sebagai siapa?"
                android:textColor="#4C5B67"
                android:textSize="16sp"
                android:fontFamily="@font/quicksand" />

            <!-- Card Orang Tua -->
            <LinearLayout
                android:id="@+id/cardOrangTua"
                android:layout_width="match_parent"
                android:layout_height="118dp"
                android:layout_marginTop="34dp"
                android:background="#FFFFFF"
                android:clickable="true"
                android:elevation="5dp"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <ImageView
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:src="@drawable/char_blue"
                    android:contentDescription="Karakter orang tua" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Orang Tua"
                        android:textColor="#2F3A2E"
                        android:textSize="21sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/quicksand" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Pantau progres dan kelola profil anak"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:fontFamily="@font/quicksand" />
                </LinearLayout>

                <TextView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:text="›"
                    android:textColor="#8DB52A"
                    android:textSize="34sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Card Anak -->
            <LinearLayout
                android:id="@+id/cardAnak"
                android:layout_width="match_parent"
                android:layout_height="118dp"
                android:layout_marginTop="18dp"
                android:background="#FFFFFF"
                android:clickable="true"
                android:elevation="5dp"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <ImageView
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:src="@drawable/char_star"
                    android:contentDescription="Karakter anak" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anak"
                        android:textColor="#2F3A2E"
                        android:textSize="21sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/quicksand" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Tambah profil anak untuk mulai bermain"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:fontFamily="@font/quicksand" />
                </LinearLayout>

                <TextView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:text="›"
                    android:textColor="#8DB52A"
                    android:textSize="34sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="FocusPlay membantu anak belajar fokus dengan cara yang menyenangkan"
                android:textColor="#5A6B76"
                android:textSize="14sp"
                android:fontFamily="@font/quicksand" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>