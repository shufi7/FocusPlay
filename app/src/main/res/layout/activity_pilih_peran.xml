<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background custom -->
    <ImageView
        android:id="@+id/bgPilihPeran"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Background"
        android:scaleType="centerCrop"
        android:src="@drawable/backgrounds" />

    <!-- Overlay tipis agar tulisan lebih jelas -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#26000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:fitsSystemWindows="true"
        android:overScrollMode="never"
        android:scrollbarStyle="outsideOverlay"
        android:smoothScrollbar="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="720dp"
            android:paddingBottom="28dp">

            <!-- Header -->
            <LinearLayout
                android:id="@+id/headerPeran"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="56dp"
                android:layout_marginEnd="24dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">



                <TextView
                    android:id="@+id/tvNamaUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/quicksand_bold"
                    android:gravity="center"
                    android:maxLines="1"
                    android:shadowColor="#66000000"
                    android:shadowDx="0"
                    android:shadowDy="3"
                    android:shadowRadius="5"
                    android:text="Halo!"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSubtitlePeran"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/quicksand"
                    android:gravity="center"
                    android:maxWidth="300dp"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="8dp"
                    android:text="Kamu ingin masuk sebagai siapa?"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Card utama -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardContainerPeran"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="26dp"
                android:layout_marginEnd="22dp"
                app:cardBackgroundColor="#F9FFFFFF"
                app:cardCornerRadius="30dp"
                app:cardElevation="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerPeran">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <!-- Judul -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/quicksand_bold"
                        android:text="Pilih Peran"
                        android:textColor="#1F2937"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <!-- Card Orang Tua -->
                    <LinearLayout
                        android:id="@+id/cardOrangTua"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/bg_card_pilihanak"
                        android:clickable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:adjustViewBounds="true"
                            android:contentDescription="Karakter orang tua"
                            android:scaleType="fitCenter"
                            android:src="@drawable/karakter_ortu" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="15dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/quicksand_bold"
                                android:text="Orang Tua"
                                android:textColor="#1F2937"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:fontFamily="@font/quicksand"
                                android:maxLines="2"
                                android:text="Pantau progres dan kelola aktivitas anak"
                                android:textColor="#5F6B7A"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/btn_pilihperan"
                            android:contentDescription="Lanjut"
                            android:padding="8dp"
                            android:scaleType="fitCenter"/>
                    </LinearLayout>

                    <!-- Card Anak -->
                    <LinearLayout
                        android:id="@+id/cardAnak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_card_pilihanak"
                        android:clickable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:adjustViewBounds="true"
                            android:contentDescription="Karakter anak"
                            android:scaleType="fitCenter"
                            android:src="@drawable/karakter_anak" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="15dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/quicksand_bold"
                                android:text="Anak"
                                android:textColor="#1F2937"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:fontFamily="@font/quicksand"
                                android:maxLines="2"
                                android:text="Mulai bermain dan latihan fokus"
                                android:textColor="#5F6B7A"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/btn_pilihperan"
                            android:contentDescription="Lanjut"
                            android:padding="8dp"
                            android:scaleType="fitCenter" />
                    </LinearLayout>

                    <!-- Info -->

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</FrameLayout>