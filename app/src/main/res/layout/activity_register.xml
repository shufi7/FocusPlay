<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background custom -->
    <ImageView
        android:id="@+id/bgRegister"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Background Register"
        android:scaleType="centerCrop"
        android:src="@drawable/background" />

    <!-- Overlay tipis agar tulisan lebih terbaca -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#16000000" />

    <!-- Area atas -->
    <LinearLayout
        android:id="@+id/topRegisterContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginStart="28dp"
        android:layout_marginTop="58dp"
        android:layout_marginEnd="28dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <ImageView
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:contentDescription="Logo FocusPlay"
            android:src="@drawable/logo_focusplay" />

        <TextView
            android:id="@+id/tvWelcomeRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/quicksand"
            android:gravity="center"
            android:shadowColor="#66000000"
            android:shadowDx="0"
            android:shadowDy="3"
            android:shadowRadius="5"
            android:text="Daftar Akun Baru"
            android:textColor="#FFFFFF"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:background="@drawable/bg_subtitle_splash"
            android:fontFamily="@font/quicksand"
            android:gravity="center"
            android:maxWidth="290dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="7dp"
            android:text="Mulai latihan fokus yang menyenangkan"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Panel putih bawah, dibuat match_parent + marginTop agar aman untuk HP pendek -->
    <LinearLayout
        android:id="@+id/cardRegisterBottom"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom"
        android:layout_marginTop="235dp"
        android:background="@drawable/bg_register_bottom_sheet"
        android:elevation="10dp"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="18dp"
                android:paddingEnd="24dp"
                android:paddingBottom="34dp">

                <!-- Handle kecil -->
                <View
                    android:layout_width="54dp"
                    android:layout_height="5dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_handle_bottom_sheet" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/quicksand"
                    android:text="Get Started"
                    android:textColor="#3566D6"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/quicksand"
                    android:text="Buat akun baru untuk melanjutkan"
                    android:textColor="#7B8794"
                    android:textSize="13sp" />

                <!-- Nama Lengkap -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/quicksand"
                    android:text="Nama Lengkap"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNamaRegister"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_soft"
                    android:fontFamily="@font/quicksand"
                    android:hint="Masukkan nama lengkap"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1F2937"
                    android:textColorHint="#A0AEC0"
                    android:textSize="14sp" />

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/quicksand"
                    android:text="Email"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etEmailRegister"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_soft"
                    android:fontFamily="@font/quicksand"
                    android:hint="Masukkan email"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1F2937"
                    android:textColorHint="#A0AEC0"
                    android:textSize="14sp" />

                <!-- Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/quicksand"
                    android:text="Password"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp">

                    <EditText
                        android:id="@+id/etPasswordRegister"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_input_soft"
                        android:fontFamily="@font/quicksand"
                        android:hint="Masukkan password"
                        android:inputType="textPassword"
                        android:paddingStart="16dp"
                        android:paddingEnd="52dp"
                        android:textColor="#1F2937"
                        android:textColorHint="#A0AEC0"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/btnTogglePasswordRegister"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Lihat password"
                        android:padding="8dp"
                        android:src="@drawable/ic_eye" />
                </FrameLayout>

                <!-- Konfirmasi Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/quicksand"
                    android:text="Konfirmasi Password"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp">

                    <EditText
                        android:id="@+id/etKonfirmasiPasswordRegister"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_input_soft"
                        android:fontFamily="@font/quicksand"
                        android:hint="Ulangi password"
                        android:inputType="textPassword"
                        android:paddingStart="16dp"
                        android:paddingEnd="52dp"
                        android:textColor="#1F2937"
                        android:textColorHint="#A0AEC0"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/btnToggleKonfirmasiPasswordRegister"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="8dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Lihat konfirmasi password"
                        android:padding="8dp"
                        android:src="@drawable/ic_eye" />
                </FrameLayout>

                <!-- Tombol daftar -->
                <Button
                    android:id="@+id/btnProsesRegister"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="22dp"
                    android:background="@drawable/bg_button_register_blue"
                    android:fontFamily="@font/quicksand"
                    android:text="Daftar Sekarang"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:fontFamily="@font/quicksand"
                        android:text="atau"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB" />
                </LinearLayout>

                <!-- Link masuk -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/quicksand"
                        android:text="Sudah punya akun?"
                        android:textColor="#7B8794"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvMasukSini"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/quicksand"
                        android:text="Masuk di sini"
                        android:textColor="#3566D6"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</FrameLayout>