<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_splash_playground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Dekorasi atas -->
        <View
            android:layout_width="115dp"
            android:layout_height="35dp"
            android:layout_marginTop="82dp"
            android:layout_marginStart="-22dp"
            android:background="@drawable/bg_cloud"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="135dp"
            android:layout_height="40dp"
            android:layout_marginTop="68dp"
            android:layout_marginEnd="-22dp"
            android:background="@drawable/bg_cloud"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="34dp"
            android:layout_marginTop="58dp"
            android:background="@drawable/bg_bubble"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="30dp"
            android:layout_marginTop="54dp"
            android:background="@drawable/bg_bubble"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Header -->
        <LinearLayout
            android:id="@+id/registerHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="54dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="82dp"
                android:layout_height="82dp"
                android:contentDescription="Logo FocusPlay"
                android:src="@drawable/logo_focusplay" />
        </LinearLayout>

        <!-- Card Register -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardRegister"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="22dp"
            android:layout_marginBottom="190dp"
            app:cardBackgroundColor="#FDFDFD"
            app:cardCornerRadius="30dp"
            app:cardElevation="6dp"
            app:layout_constraintTop_toBottomOf="@id/registerHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quicksand"
                            android:text="Daftar Akun Baru"
                            android:textColor="#1F2937"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/quicksand"
                            android:text="Lengkapi data untuk bergabung"
                            android:textColor="#7B8794"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:contentDescription="Karakter hati"
                        android:src="@drawable/char_cucumber" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:fontFamily="@font/quicksand"
                    android:text="Nama Lengkap"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNamaRegister"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_login"
                    android:fontFamily="@font/quicksand"
                    android:hint="Masukkan nama lengkap"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1F2937"
                    android:textColorHint="#A0AEC0"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/quicksand"
                    android:text="Email"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etEmailRegister"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_login"
                    android:fontFamily="@font/quicksand"
                    android:hint="Masukkan email"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1F2937"
                    android:textColorHint="#A0AEC0"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/quicksand"
                    android:text="Password"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etPasswordRegister"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_login"
                    android:fontFamily="@font/quicksand"
                    android:hint="Masukkan password"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textColor="#1F2937"
                    android:textColorHint="#A0AEC0"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnProsesRegister"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_green"
                    android:fontFamily="@font/quicksand"
                    android:text="Daftar Sekarang"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/quicksand"
                        android:text="Sudah punya akun?"
                        android:textColor="#7B8794"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvMasukSini"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/quicksand"
                        android:text="Masuk di sini"
                        android:textColor="#2F80ED"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Area bawah -->
        <View
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:background="@drawable/bg_ground_soft"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:layout_width="235dp"
            android:layout_height="112dp"
            android:layout_marginStart="-46dp"
            android:layout_marginBottom="98dp"
            android:background="@drawable/bg_hill"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:layout_width="245dp"
            android:layout_height="118dp"
            android:layout_marginEnd="-52dp"
            android:layout_marginBottom="92dp"
            android:background="@drawable/bg_hill"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="54dp"
            android:contentDescription="Karakter cloud biru"
            android:src="@drawable/char_cloud_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_marginBottom="82dp"
            android:contentDescription="Karakter diamond orange"
            android:src="@drawable/char_diamond_orange"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="54dp"
            android:contentDescription="Karakter moon ungu"
            android:src="@drawable/char_moon_purple"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>