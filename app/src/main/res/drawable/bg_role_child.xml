<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Saat ditekan -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#EAF9D8" />
            <corners android:radius="26dp" />
            <stroke
                android:width="2dp"
                android:color="#B5E48C" />
        </shape>
    </item>

    <!-- Normal -->
    <item>
        <shape>
            <solid android:color="#F7FDEB" />
            <corners android:radius="26dp" />
            <stroke
                android:width="1dp"
                android:color="#D9F4B9" />
        </shape>
    </item>

</selector>