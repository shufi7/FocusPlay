<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow paling luar, sangat lembut -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#10000000" />
        </shape>
    </item>

    <!-- Shadow tengah -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#14000000" />
        </shape>
    </item>

    <!-- Lingkaran utama -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="#F2FFFFFF" />

            <stroke
                android:width="1dp"
                android:color="#FFFFFF" />
        </shape>
    </item>

</layer-list>