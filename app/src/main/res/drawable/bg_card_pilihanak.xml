<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Saat ditekan -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#fff" />
            <corners android:radius="26dp" />
            <stroke
                android:width="2dp"
                android:color="#f0e9c4" />
        </shape>
    </item>

    <!-- Normal -->
    <item>
        <shape>
            <solid android:color="#fff" />
            <corners android:radius="26dp" />
            <stroke
                android:width="2dp"
                android:color="#f0e9c4" />
        </shape>
    </item>

</selector>